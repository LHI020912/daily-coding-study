<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>마우스 이벤트</title>
		<script type="text/javascript">
			window.onload = function(){
				let birdImg = document.getElementById('birdImg');
				//해당 객체에 마우스가 진입하면 투명도를 0.5처리
				birdImg.onmouseober = () => birdImg.style.opacity=0.5;
			};
			
			// 문서 상에서 오른쪽 마우스 클릭했을 때 이벤트 처리 : contextmenu

		</script>
	</head>
	<body>
		<img id="birdImg" src="image/bird.jpg">
	</body>
</html>





