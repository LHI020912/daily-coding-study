<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!DOCTYPE html>
<html>
<head>
    <style>
        
    </style>
    <script type="text/javascript">
		// 브라우저 해시는 서버는 처리 불가능하므로 스크립트 통해 브라우저에서 url해결 후 서버로 요청을 진행
		// react는 url이 #통해 연결돼도 서버 요청과 연결되지 않으면 자유롭긴함, 연결되면 문제있음...
		// 브라우저 요청에 hash가 포함되어 있는지 확인
		// 현재브라우저의 url을 hash 기준 분리
		// https://www.naver.com/#example-> #기준으로 분리, 첫번째 문자열을 반환(example반환)
		const hash = window.location.hash.slice(1);
		
		if(hash){
			window.location.href
		}
    </script>
    <meta charset="UTF-8">
    <title>DOM Based XSS 공격</title>
</head>

<body>
<h1>DOM Based XSS 공격</h1>

<div class="container">
    <a id="first" href="#first.jsp" class="item">First 바로가기</a>
    <a id="second" href="#second.jsp" class="item">Second 바로가기</a>
</div>

</body>
</html>