package sec02;

import java.io.IOException;

import javax.servlet.ServletConfig;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

@WebServlet("/bookInsert")
public class bookServlet extends HttpServlet {
	private static final long serialVersionUID = 1L;
       
    public bookServlet() {
        super();
    }

	public void init(ServletConfig config) throws ServletException {
		System.out.println("init 메서드 호출");
	}

	protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		response.setCharacterEncoding("utf-8");
		String b_num = request.getParameter("b_num");
		String b_name = request.getParameter("b_name");
		String b_author = request.getParameter("b_author");
		String b_price = request.getParameter("b_price");
		String b_date = request.getParameter("b_date");
		String b_stack = request.getParameter("b_stack");
		String p_num = request.getParameter("p_num");

		System.out.println("도서번호: "+b_num);
		System.out.println("도서명: "+b_name);
		System.out.println("저자: "+b_author);
		System.out.println("가격: "+b_price);
		System.out.println("발행일: "+b_date);
		System.out.println("재고: "+b_stack);
		System.out.println("출판사번호: "+p_num);
		
	}

	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		doGet(request, response);
	}

}
