<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>회원가입 폼</title>
<style type="text/css">
	body{margin:auto 0;
		justify-content: center;
		align-items: center;}
	header{text-align: center;}
	table{margin-left:40px;}
	#num{width:50px;}
	#button{display: inline-block;}
</style>
</head>
<body>
<header><h1>회원 가입</h1></header><hr>
<form name="joinFrom" method="post" action="join">
<table>
	<tr><td>성명</td><td><input type="text" name="user_name"></td></tr>
	<tr><td>ID</td><td><input type="text" name="user_id"></td></tr>
	<tr><td>비밀번호</td><td><input type="text" name="user_pw"></td></tr>
	
	<tr><td>휴대폰 번호</td><td><input type="text" name="first_num" id="num"> 
	 						- <input type="text" name="first_num" id="num"> 
	 						- <input type="text" name="first_num" id="num"></td></tr>
	
	<tr><td>학년</td><td><input type="radio" name="grade" value="1학년">1학년
						<input type="radio" name="grade" value="2학년">2학년
						<input type="radio" name="grade" value="3학년">3학년
						<input type="radio" name="grade" value="4학년">4학년</td></tr>
						
	<tr><td>관심분야</td><td>	<input type="checkBox" name="subject" value="웹 프로그래밍">웹 프로그래밍
							<input type="checkBox" name="subject" value="파이썬">파이썬
							<input type="checkBox" name="subject" value="빅데이터">빅데이터
							<input type="checkBox" name="subject" value="자바 프로그래밍">자바 프로그래밍</td></tr>
							
	<tr><td>학과</td><td><select><option>프론트</option>
								<option>백엔드</option>
								<option>풀스택</option></select></td></tr>
	<tr id="button"><td rowspan="2"><input type="submit" value="완료"><input type="reset" value="취소"></td></tr>
</table>
</form>
</body>
</html>